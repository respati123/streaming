						"description": "Top 10 donatur berdasarkan total amount. Grouped by name."
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"top\": [\n\t\t{\n\t\t\t\"name\": \"Budi Santoso\",\n\t\t\t\"totalAmount\": 150000,\n\t\t\t\"donationCount\": 3\n\t\t}\n\t]\n}"
