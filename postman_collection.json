{
	"info": {
		"name": "Streaming Overlay API",
		"description": "API collection untuk testing streaming overlay project. Backend jalan di localhost:3000.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000"
		}
	],
	"item": [
		{
			"name": "General",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								""
							]
						},
						"description": "Cek server status."
					},
					"response": []
				}
			]
		},
		{
			"name": "Test Endpoints",
			"description": "Endpoint buat simulasi & testing tanpa Streamer.bot.",
			"item": [
				{
					"name": "Send Chat Message",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"userId\": \"test-user-001\",\n\t\"name\": \"Respati\",\n\t\"message\": \"Halo chat!\",\n\t\"profileImageUrl\": null,\n\t\"isOwner\": false,\n\t\"isModerator\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/test/chat",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"test",
								"chat"
							]
						},
						"description": "Kirim satu chat message. Kalau userId belum ada, auto-create user baru. Field `message` wajib, sisanya opsional."
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"ok\": true,\n\t\"user\": \"Respati\",\n\t\"tier\": \"viewer\"\n}"
						}
					]
				},
				{
					"name": "Burst Chat (Multiple)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"delay\": 300,\n\t\"messages\": [\n\t\t{ \"userId\": \"user-1\", \"name\": \"Andi\", \"message\": \"Pagi semuanya!\" },\n\t\t{ \"userId\": \"user-2\", \"name\": \"Sari\", \"message\": \"Mabar yuk\" },\n\t\t{ \"userId\": \"user-3\", \"name\": \"Budi\", \"message\": \"GG bro\", \"isModerator\": true }\n\t]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/test/chat/burst",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"test",
								"chat",
								"burst"
							]
						},
						"description": "Kirim banyak chat sekaligus dengan delay antar message. `delay` dalam ms (default 300). Setiap item di `messages` formatnya sama kayak Send Chat."
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"ok\": true,\n\t\"sent\": 3,\n\t\"messages\": [\n\t\t\"Andi: Pagi semuanya!\",\n\t\t\"Sari: Mabar yuk\",\n\t\t\"Budi: GG bro\"\n\t]\n}"
						}
					]
				},
				{
					"name": "Test Transition Overlay",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"phase\": \"start\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/test/transition",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"test",
								"transition"
							]
						},
						"description": "Trigger transition overlay di frontend. `phase` bisa \"start\" atau \"end\"."
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"ok\": true,\n\t\"phase\": \"start\"\n}"
						}
					]
				},
				{
					"name": "Test Donation Alert",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"donatorName\": \"GenerousUser\",\n\t\"amount\": 50000,\n\t\"message\": \"Semangat streaming nya bro!\",\n\t\"skipTts\": false\n},\n\t\"skipTts\": false"
						},
						"url": {
							"raw": "{{base_url}}/api/test/donation",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"test",
								"donation"
							]
						},
						"description": "Trigger donation alert di overlay. Semua field opsional (default: donatorName=\"TestDonator\", amount=10000, message=\"\")."
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"ok\": true,\n\t\"donation\": {\n\t\t\"id\": 5,\n\t\t\"donatorName\": \"GenerousUser\",\n\t\t\"amountRaw\": 50000,\n\t\t\"message\": \"Semangat streaming nya bro!\",\n\t\t\"saweriaId\": \"test-1777878417733-abc123\",\n\t\t\"type\": \"donation\",\n\t\t\"createdAt\": \"2026-05-04T07:09:16.598Z\"\n\t\t}\n\t}"
						}
					]
				},
				{
					"name": "Test AI Dialogue Box",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"Budi\",\n\t\"message\": \"Lagi main game apa nih bro?\",\n\t\"skipTts\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/test/ai-dialogue",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"test",
								"ai-dialogue"
							]
						},
						"description": "Trigger AI dialogue box di overlay. AI akan generate reply berdasarkan pesan user. Set `skipTts: true` buat skip TTS (lebih cepat)."
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"ok\": true,\n\t\"userMessage\": \"Lagi main game apa nih bro?\",\n\t\"aiResponse\": \"Lagi main Valorant nih, rank naik terus! Kamu mau mabar nggak?\"\n}"
						}
					]
				},
				{
					"name": "Reset All Test Data",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": ""
						},
						"url": {
							"raw": "{{base_url}}/api/test/reset",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"test",
								"reset"
							]
						},
						"description": "\u26a0\ufe0f Hapus semua data test: donations, messages, streams, users. Gunakan dengan hati-hati!"
					},
					"response": [
						{
							"name": "Success Response",
							"status": "200",
							"body": "{\n\t\"ok\": true,\n\t\"message\": \"All test data cleared\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "Saweria (Donation)",
			"description": "Webhook dan query untuk donasi Saweria.",
			"item": [
				{
					"name": "Webhook (Saweria \u2192 Server)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"version\": \"1\",\n\t\"created_at\": \"2026-05-04T15:30:00.000Z\",\n\t\"id\": \"00000000-0000-0000-0000-000000000001\",\n\t\"type\": \"donation\",\n\t\"amount_raw\": 50000,\n\t\"cut\": 5000,\n\t\"donator_name\": \"Someguy\",\n\t\"donator_email\": \"someguy@example.com\",\n\t\"donator_is_user\": false,\n\t\"message\": \"THIS IS A FAKE MESSAGE! HAVE A GOOD ONE\",\n\t\"etc\": {\n\t\t\"amount_to_display\": 50000\n\t}\n}"
